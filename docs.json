{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fundable",
  "colors": {
    "primary": "#000000",
    "light": "#EFEFEF",
    "dark": "#000000"
  },
  "favicon": "/logo/Mobius.webp",
  "logo": {
    "light": "/logo/fundable_w_name.png",
    "dark": "/logo/fundable_w_name_white.png"
  },
  "openapi": [
    "/openapi/openapi-deals.yaml",
    "/openapi/openapi-companies.yaml",
    "/openapi/openapi-investors.yaml",
    "/openapi/openapi-people.yaml",
    "/openapi/openapi-alerts.yaml",
    "/openapi/openapi-other.yaml"
  ],
  "api": {
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "baseUrl": "https://www.tryfundable.ai/api/v1",
    "examples": {
      "autogenerate": false
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "authentication",
              "usage"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Deals",
            "pages": [
              "api-reference/deals/list",
              "api-reference/deals/get",
              "api-reference/deals/investors"
            ]
          },
          {
            "group": "Companies",
            "pages": [
              "api-reference/companies/list",
              "api-reference/companies/get",
              "api-reference/companies/deals",
              "api-reference/companies/search"
            ]
          },
          {
            "group": "Investors",
            "pages": [
              "api-reference/investors/list",
              "api-reference/investors/get",
              "api-reference/investors/deals",
              "api-reference/investors/search"
            ]
          },
          {
            "group": "People",
            "pages": [
              "api-reference/people/list",
              "api-reference/people/get",
              "api-reference/people/deals",
              "api-reference/people/search"
            ]
          },
          {
            "group": "Filters",
            "pages": [
              "api-reference/industries/search",
              "api-reference/locations/search"
            ]
          },
          {
            "group": "Alerts",
            "pages": [
              "api-reference/alerts/list",
              "api-reference/alerts/configurations"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:jacob@tryfundable.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://www.tryfundable.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/fundable-ai/"
    }
  }
}
